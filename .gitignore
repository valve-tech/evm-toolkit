.DS_Store

# Local-only directory-scoped gitconfig override (loaded via includeIf
# in ~/.gitconfig). Never commit — its contents depend on the local
# checkout's identity setup.
.gitconfig.valvecitydev

# Per-session AI checkpoint notes (Claude Code's progress log). Local
# to each working tree; never shipped, never committed.
progress.txt

# Generated TypeDoc HTML — regenerated by `yarn docs:build` for local
# browsing only. docs.valve.city renders from the committed JSON +
# manifest; HTML would be dead weight in the repo. The JSON model
# files (docs/api/*.json), trueblocks-openapi.yaml, manifest.json,
# and README.md ARE committed — they're the contract.
docs/api/*/
.docs-check-tmp/
.superpowers/
