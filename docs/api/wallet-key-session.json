              "comment": {
                "summary": [
                  {
                    "kind": "text",
                    "text": "Tear the session down: "
                  },
                  {
                    "kind": "code",
                    "text": "`clear()`"
                  },
                  {
                    "kind": "text",
                    "text": " the key AND remove every listener\nthis session registered ("
                  },
                  {
                    "kind": "code",
                    "text": "`accountsChanged`"
                  },
                  {
                    "kind": "text",
                    "text": " / "
                  },
                  {
                    "kind": "code",
                    "text": "`chainChanged`"
                  },
                  {
                    "kind": "text",
                    "text": " on the\nprovider, "
                  },
                  {
                    "kind": "code",
                    "text": "`pagehide`"
                  },
                  {
                    "kind": "text",
                    "text": " on "
                  },
                  {
                    "kind": "code",
                    "text": "`window`"
                  },
                  {
                    "kind": "text",
                    "text": "). Call when the session's owner\nunmounts — e.g. a React "
                  },
                  {
                    "kind": "code",
                    "text": "`useEffect`"
                  },
                  {
                    "kind": "text",
                    "text": " cleanup — so repeated\ncreate/destroy cycles don't accumulate listeners. Idempotent; after\n"
                  },
                  {
                    "kind": "code",
                    "text": "`dispose()`"
                  },
                  {
                    "kind": "text",
                    "text": " the session no longer responds to provider events."
                  }
                ]
