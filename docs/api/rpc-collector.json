          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Ping each endpoint and reorder by measured latency.\n\nOpt-in and network-bound — the rest of this package is pure. Dead\nendpoints are dropped unless "
              },
              {
                "kind": "code",
                "text": "`keepDead`"
              },
              {
                "kind": "text",
                "text": " is set. Websocket endpoints are\nnot probed; they are kept, unmeasured, and sorted after measured ones."
              }
            ]
          },
