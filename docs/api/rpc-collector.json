    {
      "id": 1,
      "name": "collectRpcs",
      "variant": "declaration",
      "kind": 64,
      "flags": {},
      "sources": [
        {
          "fileName": "collect.ts",
          "line": 89,
          "character": 16
        }
      ],
      "signatures": [
        {
          "id": 2,
          "name": "collectRpcs",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Resolve a chain to its public RPC endpoints, ordered privacy-first.\n\nPure and synchronous — the dataset is compiled into the package, so no\nnetwork access happens here. Nothing is filtered out unless you ask:\nby default every endpoint for the chain is returned, ordered so the\nleast-tracking providers come first."
              }
            ],
            "blockTags": [
              {
                "tag": "@throws",
                "content": [
                  {
                    "kind": "text",
                    "text": "if the chain is not in the dataset."
                  }
                ]
              },
              {
                "tag": "@throws",
                "content": [
                  {
                    "kind": "text",
                    "text": "if neither "
                  },
                  {
                    "kind": "code",
                    "text": "`chainId`"
                  },
                  {
                    "kind": "text",
                    "text": " nor "
                  },
                  {
                    "kind": "code",
                    "text": "`chainName`"
                  },
                  {
                    "kind": "text",
                    "text": " is supplied."
                  }
                ]
              }
            ]
          },
