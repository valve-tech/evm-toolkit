      ],
      "signatures": [
        {
          "id": 2,
          "name": "walkErrorCause",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Walk an error and its "
              },
              {
                "kind": "code",
                "text": "`cause`"
              },
              {
                "kind": "text",
                "text": " chain, yielding each link in order, starting\nwith the error itself. Stops at "
              },
              {
                "kind": "code",
                "text": "`null`"
              },
              {
                "kind": "text",
                "text": "/"
              },
              {
                "kind": "code",
                "text": "`undefined`"
              },
              {
                "kind": "text",
                "text": ", when the chain hits a\nprimitive that has no "
              },
              {
                "kind": "code",
                "text": "`cause`"
              },
              {
                "kind": "text",
                "text": ", or when "
              },
              {
                "kind": "code",
                "text": "`maxDepth`"
              },
              {
                "kind": "text",
                "text": " is reached. Default depth\nis 8 — enough for every viem stack we've seen in the wild without risking\na runaway loop on a circular chain."
              }
            ],
            "blockTags": [
              {
                "tag": "@example",
                "content": [
                  {
                    "kind": "code",
                    "text": "```ts\nfor (const link of walkErrorCause(error)) {\n  if (typeof link === 'object' && link && 'code' in link && link.code === 4001) {\n    return true\n  }\n}\n```"
                  }
                ]
              }
            ]
          },
