      "signatures": [
        {
          "id": 8,
          "name": "isUserRejectionError",
          "variant": "signature",
          "kind": 4096,
          "flags": {},
          "comment": {
            "summary": [
              {
                "kind": "text",
                "text": "Check whether an error represents a user-initiated wallet rejection.\n\nWalks the cause chain (viem nests rejections several layers deep —\ntypically "
              },
              {
                "kind": "code",
                "text": "`ContractFunctionExecutionError`"
              },
              {
                "kind": "text",
                "text": " → "
              },
              {
                "kind": "code",
                "text": "`RpcRequestError`"
              },
              {
                "kind": "text",
                "text": " →\n"
              },
              {
                "kind": "code",
                "text": "`UserRejectedRequestError`"
              },
              {
                "kind": "text",
                "text": ") and checks three independent signals at\neach level:\n  1. **EIP-1193 "
              },
              {
                "kind": "code",
                "text": "`code === 4001`"
              },
              {
                "kind": "text",
                "text": "** — the spec-mandated rejection code,\n     language-independent. The most reliable signal when present.\n  2. **Error name "
              },
              {
                "kind": "code",
                "text": "`UserRejectedRequestError`"
              },
              {
                "kind": "text",
                "text": "** — viem's class name.\n  3. **Message text regex** — fallback for wallets that bypass the\n     standard error class.\n\nAny one of those three is sufficient at any level in the chain."
              }
            ]
          },
          "sources": [
            {
              "fileName": "rejection.ts",
              "line": 45,
              "character": 16
            }
          ],
          "parameters": [
            {
              "id": 9,
              "name": "error",
              "variant": "param",
              "kind": 32768,
              "flags": {},
              "type": {
                "type": "intrinsic",
                "name": "unknown"
              }
            }
          ],
          "type": {
            "type": "intrinsic",
            "name": "boolean"
          }
        }
      ]
    },
    {
      "id": 1,
      "name": "walkErrorCause",
      "variant": "declaration",
      "kind": 64,
      "flags": {},
      "comment": {
        "summary": [],
        "blockTags": [
          {
            "tag": "@fileoverview",
            "content": [
              {
                "kind": "text",
                "text": "Public API of "
              },
              {
                "kind": "code",
                "text": "`@valve-tech/viem-errors`"
              },
